{
  "name": "@nova/turn-context",
  "version": "1.0.0",
  "description": "Turn context plugin: injects per-turn reminders, entity identity, and semantic recall into agent prompts",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "pg": "^8.11.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
