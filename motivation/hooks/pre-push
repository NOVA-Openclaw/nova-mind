#!/bin/bash
# NOVA Git Workflow Enforcement - Pre-push Hook
# Issue #26: Enforce PR-only workflow for main/master branches

# Read all refs being pushed
while read local_ref local_sha remote_ref remote_sha; do
  # Extract branch name from remote ref (refs/heads/main -> main)
  branch=$(echo "$remote_ref" | sed 's|refs/heads/||')
  
  # Rule 1: Block direct pushes to main/master for ALL agents
  if [[ "$branch" == "main" || "$branch" == "master" ]]; then
    echo "❌ Direct push to $branch blocked!"
    echo ""
    echo "The NOVA workflow requires all changes to main/master go through PRs."
    echo ""
    echo "To contribute:"
    echo "  1. Push to a feature branch (git push origin your-branch-name)"
    echo "  2. Create a PR (gh pr create)"
    echo "  3. Have Gidget (git-agent) merge it"
    echo ""
    exit 1
  fi
  
  # Rule 2: Check agent permissions for feature branches
  AGENT_ID="${CLAWDBOT_AGENT_ID:-}"
  CURRENT_USER="${USER:-}"
  
  # Allow human user (newhart) to push
  if [[ "$CURRENT_USER" == "newhart" ]]; then
    # Human users can push to feature branches
    continue
  fi
  
  # Block if no agent ID is set (NOVA main or unknown agent)
  if [[ -z "$AGENT_ID" ]]; then
    echo "❌ NOVA GIT BLOCKED"
    echo ""
    echo "No CLAWDBOT_AGENT_ID detected. Direct git operations require an agent identity."
    echo ""
    echo "Authorized agents:"
    echo "  - claude-code (Coder) - Can push feature branches and create PRs"
    echo "  - git-agent (Gidget) - Can push feature branches and merge PRs"
    echo ""
    echo "If you are a human user, git operations should work normally."
    echo "If you are an authorized agent, ensure CLAWDBOT_AGENT_ID is set."
    echo ""
    exit 1
  fi
  
  # Allow authorized agents (claude-code and git-agent) to push feature branches
  if [[ "$AGENT_ID" == "claude-code" || "$AGENT_ID" == "git-agent" ]]; then
    # These agents can push to feature branches
    continue
  fi
  
  # Block any other agent
  echo "❌ Git push blocked for agent: $AGENT_ID"
  echo ""
  echo "Only authorized agents can push to this repository:"
  echo "  - claude-code (Coder) - Feature branches and PRs"
  echo "  - git-agent (Gidget) - Feature branches and PR merges"
  echo ""
  exit 1
done

# All checks passed
exit 0
